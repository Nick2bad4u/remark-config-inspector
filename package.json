{
    "name": "stylelint-config-inspector",
    "version": "2.1.0",
    "private": false,
    "description": "A visual tool for inspecting and understanding your Stylelint configs",
    "keywords": [
        "@stylelint",
        "@stylelint/config-inspector",
        "config",
        "eslint-inspector",
        "inspector",
        "stylelint",
        "stylelint-config",
        "stylelint-config-inspector",
        "stylelint-inspector",
        "stylelint-plugin",
        "tool",
        "visualization"
    ],
    "homepage": "https://github.com/Nick2bad4u/Stylelint-Config-Inspector#readme",
    "bugs": "https://github.com/Nick2bad4u/Stylelint-Config-Inspector/issues",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/Stylelint-Config-Inspector.git"
    },
    "funding": "https://opencollective.com/stylelint",
    "license": "Apache-2.0",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com> (https://nick2bad4u.github.io/eslint-plugin-typefest)",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://nick2bad4u.github.io/eslint-plugin-typefest"
        }
    ],
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/cli.d.mts",
                "default": "./dist/cli.mjs"
            },
            "require": {
                "types": "./dist/cli.d.cts",
                "default": "./dist/cli.cjs"
            },
            "default": "./dist/cli.mjs"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/cli.cjs",
    "types": "./dist/cli.d.mts",
    "bin": {
        "stylelint-config-inspector": "bin.mjs"
    },
    "files": [
        "*.mjs",
        "dist"
    ],
    "scripts": {
        "build": "nuxt build && tsdown",
        "changelog:release-notes": "git-cliff --config cliff.toml --current --strip all",
        "check": "npm run lint && npm run typecheck && npm run test && npm run build",
        "contrib": "all-contributors",
        "contrib:add": "all-contributors add",
        "contrib:check": "all-contributors check",
        "contrib:compare": "npm run contrib:check",
        "contrib:generate": "all-contributors generate",
        "dev": "nuxt dev",
        "lint": "npm run lint:node-version-files && npm run lint:prettier && eslint --cache --cache-strategy content --cache-location .cache/.eslintcache",
        "lint:all": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache && npm run lint:stylelint && npm run typecheck",
        "lint:all:fix": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache --fix && npm run lint:stylelint:fix && npm run typecheck && npm run lint:prettier:fix",
        "lint:fix": "npm run sync:node-version-files && npm run lint:prettier:fix && eslint --cache --cache-strategy content --cache-location .cache/.eslintcache --fix",
        "lint:node-version-files": "node scripts/sync-node-version-files.mjs --check",
        "lint:package": "npm run lint:node-version-files && npm run lint:package-sort && npm run lint:packagelintrc && npm run lint:tsdown",
        "lint:package:strict": "npm run lint:node-version-files && npm run lint:package-sort && npm run lint:package-check && npm run lint:packagelintrc && npm run lint:tsdown",
        "lint:package-check": "publint && attw --pack .",
        "lint:package-check:strict": "publint && attw --pack . --profile strict",
        "lint:package-sort": "sort-package-json \"./package.json\" \"./docs/docusaurus/package.json\"",
        "lint:package-sort-check": "sort-package-json --check \"./package.json\" \"./docs/docusaurus/package.json\"",
        "lint:packagelintrc": "npmPkgJsonLint . --config .npmpackagejsonlintrc.json",
        "lint:prettier": "prettier --check .",
        "lint:prettier:fix": "prettier --write .",
        "lint:release": "npm run lint:all:fix && npm run lint:package-sort && npm run lint:package:strict",
        "lint:stylelint": "stylelint \"**/*.{css,scss,sass,less,pcss,vue,html}\" --allow-empty-input --cache --cache-location .cache/.stylelintcache --ignore-pattern \"playwright-report/**\" --ignore-pattern \"test-results/**\" --ignore-pattern \".nuxt/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"docs/docusaurus/build/**\"",
        "lint:stylelint:fix": "stylelint \"**/*.{css,scss,sass,less,pcss,vue,html}\" --allow-empty-input --cache --cache-location .cache/.stylelintcache --ignore-pattern \"playwright-report/**\" --ignore-pattern \"test-results/**\" --ignore-pattern \".nuxt/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"docs/docusaurus/build/**\" --fix",
        "lint:tsdown": "tsdown --no-write",
        "lint:tsdown:build": "tsdown",
        "prepack": "npm run build",
        "prebench": "npm run build",
        "prepare": "nuxt prepare",
        "release:check": "npm run check",
        "prestart": "npm run build",
        "start": "node bin.mjs",
        "sync:node-version-files": "node scripts/sync-node-version-files.mjs",
        "test": "vitest --run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:ui": "playwright test --ui",
        "typecheck": "nuxt typecheck",
        "update-deps": "npx ncu -i --install never && npm install --force"
    },
